# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=                # web app only
SUPABASE_SERVICE_ROLE_KEY=        # agent only — never in web bundle
DATABASE_URL=                     # postgres connection string for migrations

# Gemini
GEMINI_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                 # numeric, your DM with the bot
TELEGRAM_USER_ID=                 # numeric, used to authorize inbound messages
TELEGRAM_WEBHOOK_SECRET=          # random string, set when registering webhook

# Web
PUBLIC_WEB_URL=https://loob.example.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
ALLOWED_USER_EMAIL=               # only this email can sign in via magic link

# Paper-trading model (optional — sensible defaults if unset)
# MAX_OPEN_EXPOSURE_USD=10000     # hard cap on total open notional across paper trades
# PAPER_SLIPPAGE_BPS=5            # applied to entry & exit prices
# PAPER_FEE_BPS=10                # per-leg fee in bps (round-tripped on close)

# Future (do not set in v1)
# EXECUTION_MODE=paper            # 'paper' | 'live'  — flipping to live is intentional and gated
# WALLET_PRIVATE_KEY=             # only when EXECUTION_MODE=live
