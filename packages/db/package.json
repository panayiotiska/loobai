{
  "name": "@loob/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "tsx src/migrate.ts",
    "migrate:local": "dotenv -e ../../.env -- tsx src/migrate.ts",
    "seed:formula": "tsx src/seed-formula.ts",
    "seed:formula:local": "dotenv -e ../../.env -- tsx src/seed-formula.ts"
  },
  "dependencies": {
    "@loob/shared": "workspace:*",
    "@supabase/supabase-js": "^2.44.4"
  },
  "devDependencies": {
    "@types/pg": "^8.11.6",
    "dotenv-cli": "^7.4.2",
    "pg": "^8.12.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.1.9"
  }
}
